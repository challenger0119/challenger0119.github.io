# Set personal aliases, overriding those provided by oh-my-zsh libs,
# users are encouraged to define aliases within the ZSH_CUSTOM folder.
# For a full list of active aliases, run `alias`.
# Example aliases
# alias zshconfig="mate ~/.zshrc"
# alias ohmyzsh="mate ~/.oh-my-zsh"
alias flt="flutter"
alias podi="pod install --repo-update"
alias fpod="bundle exec pod install"
alias flt-app="flutter run --use-application-binary"
alias sm="/Applications/Sublime\ Merge.app/Contents/SharedSupport/bin/smerge" 
alias podclean="sh ~/Documents/sh/removepod.sh"
alias spaceclean="sh ~/Documents/sh/clean.sh"
alias sim="open -a Simulator"
alias simxr="xcrun instruments -w 'iPhone Xʀ (12.2)'"
alias eesc="EEScaffold"
alias lint="swiftlint > ~/Desktop/lint.txt"
alias ezsh="vim ~/.zshrc"
alias uzsh="source ~/.zshrc"
alias vs="/Applications/Visual\ Studio\ Code.app/Contents/Resources/app/bin/code"
alias ide="/Applications/IntelliJ\ IDEA.app/Contents/MacOS/idea $(pwd)"
alias uml="source ~/Documents/Runnable/plantuml/shell/umlcreate.sh"
alias umlgo="source ~/Documents/Runnable/plantuml/shell/umlgenerate.sh"
alias umlhp="open ~/Documents/Runnable/plantuml/help.pdf"
alias bdex="bundle exec"
alias sandbox="sh ~/Documents/sh/sandbox.sh"
alias exalias="cat ~/.zshrc | grep alias >> zsh_alias"
