<h2 id="иДЪжЬђ">иДЪжЬђ</h2>

<p>еРИеєґдЄНеРМ.a жЦЗдїґдЄ≠зЪДarm64 еТМ armv7 жЮґжЮД</p>

<div class="language-bash highlighter-rouge"><div class="highlight"><pre class="highlight"><code><span class="c"># !/bin/bash</span>

<span class="nb">echo</span> <span class="s2">"----еРИеєґеЉАеІЛ----"</span>

<span class="c"># иОЈеПЦељУеЙНзЫЃељХ</span>
<span class="nv">currentDir</span><span class="o">=</span><span class="s2">"</span><span class="si">$(</span><span class="nb">pwd</span><span class="si">)</span><span class="s2">"</span>

<span class="c"># жЬАзїИзїУжЮЬиЈѓеЊД</span>
<span class="nv">finalLibDir</span><span class="o">=</span><span class="s2">"</span><span class="nv">$currentDir</span><span class="s2">/finallib"</span>

<span class="c"># еОЯеІЛеЇУдљНзљЃ</span>
<span class="nv">originLibDir</span><span class="o">=</span><span class="s2">"</span><span class="nv">$currentDir</span><span class="s2">/origin"</span>

<span class="c"># йЗНжЦ∞еИЫеїЇеЇУдљНзљЃ</span>
<span class="nv">recreateDir</span><span class="o">=</span><span class="s2">"</span><span class="k">${</span><span class="nv">currentDir</span><span class="k">}</span><span class="s2">/recreated"</span>

<span class="c"># еЇУеИЖз¶їдљНзљЃ</span>
<span class="nv">explitDir</span><span class="o">=</span><span class="s2">"libexplit"</span>
<span class="nv">libExplit</span><span class="o">=</span><span class="s2">"</span><span class="nv">$recreateDir</span><span class="s2">/</span><span class="nv">$explitDir</span><span class="s2">"</span>

<span class="c"># еЇУеРИеєґдљНзљЃ</span>
<span class="nv">resultDir</span><span class="o">=</span><span class="s2">"libresult"</span>
<span class="nv">libResult</span><span class="o">=</span><span class="s2">"</span><span class="nv">$recreateDir</span><span class="s2">/</span><span class="nv">$resultDir</span><span class="s2">"</span>

<span class="c"># жЬАзїИ.aеРНзІ∞</span>
<span class="nv">libName</span><span class="o">=</span><span class="s2">"libxxxOther"</span>

<span class="c"># .oжЦЗдїґдљНзљЃ</span>
<span class="nv">odir64</span><span class="o">=</span><span class="s2">"</span><span class="nv">$libExplit</span><span class="s2">/arm64"</span>
<span class="nv">odirv7</span><span class="o">=</span><span class="s2">"</span><span class="nv">$libExplit</span><span class="s2">/armv7"</span>

<span class="c"># дЄНеРМеє≥еП∞жЦ∞зЪД .aжЦЗдїґиЈѓеЊД</span>
<span class="nv">libArm64</span><span class="o">=</span><span class="s2">"</span><span class="nv">$libResult</span><span class="s2">/</span><span class="k">${</span><span class="nv">libName</span><span class="k">}</span><span class="s2">_arm64.a"</span>
<span class="nv">libArmv7</span><span class="o">=</span><span class="s2">"</span><span class="nv">$libResult</span><span class="s2">/</span><span class="k">${</span><span class="nv">libName</span><span class="k">}</span><span class="s2">_armv7.a"</span>

<span class="c"># йЬАи¶БеРИеєґзЪДеЇУеРН</span>
<span class="nv">libsToCombine</span><span class="o">=(</span><span class="s2">"lib1.a"</span> <span class="s2">"lib2.a"</span> <span class="s2">"lib3.a"</span><span class="o">)</span>

<span class="c"># дЄНйЬАи¶БеРИеєґзЪДеЇУеРН</span>
<span class="nv">libsToCopy</span><span class="o">=(</span><span class="s2">"xx.framework"</span> <span class="s2">"lib4.a"</span> <span class="s2">"lib5.a"</span> <span class="s2">"xxx.md"</span><span class="o">)</span>


<span class="nb">echo</span> <span class="s2">"1. ж£АжЯ•еТМеИЫеїЇзЫЃељХ--&gt;"</span>
<span class="k">for </span><span class="nb">dir </span><span class="k">in</span> <span class="nv">$finalLibDir</span> <span class="nv">$recreateDir</span> <span class="nv">$libExplit</span> <span class="nv">$odir64</span> <span class="nv">$odirv7</span> <span class="nv">$libResult</span>
<span class="k">do
	</span><span class="nb">echo</span> <span class="nv">$dir</span>
	<span class="k">if</span> <span class="o">[</span> <span class="o">!</span> <span class="nt">-e</span> <span class="nv">$dir</span> <span class="o">]</span>
	<span class="k">then
		</span><span class="nb">mkdir</span> <span class="nv">$dir</span>
	<span class="k">fi
done

</span><span class="nb">echo</span> <span class="s2">"2. дїОеОЯеІЛеЇУзЫЃељХдЄ≠жЛЈиіЭйЬАи¶БеРИеєґзЪДеЇУ--&gt;"</span>
<span class="k">for </span>lname <span class="k">in</span> <span class="k">${</span><span class="nv">libsToCombine</span><span class="p">[@]</span><span class="k">}</span>
<span class="k">do
