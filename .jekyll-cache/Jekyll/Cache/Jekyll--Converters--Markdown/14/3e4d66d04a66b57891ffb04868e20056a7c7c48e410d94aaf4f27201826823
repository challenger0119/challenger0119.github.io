	<span class="nb">cp</span> <span class="nt">-f</span> <span class="s2">"</span><span class="nv">$originLibDir</span><span class="s2">/</span><span class="nv">$lname</span><span class="s2">"</span> <span class="s2">"</span><span class="nv">$recreateDir</span><span class="s2">/"</span>
<span class="k">done


</span><span class="nb">echo</span> <span class="s2">"3. еИЖз¶їеЗЇеЇУдЄ≠зЪДзЫЃж†З.oжЦЗдїґ--&gt;"</span>
<span class="k">for </span>liba <span class="k">in</span> <span class="si">$(</span><span class="nb">ls</span> <span class="nv">$recreateDir</span><span class="si">)</span>
<span class="k">do
	if</span> <span class="o">[[</span> <span class="nv">$liba</span> <span class="o">!=</span> <span class="nv">$explitDir</span> <span class="o">&amp;&amp;</span> <span class="nv">$liba</span> <span class="o">!=</span> <span class="nv">$resultDir</span> <span class="o">]]</span>
	<span class="k">then</span>
		<span class="c"># .a жЦЗдїґеРНйХњеЇ¶</span>
		<span class="nv">libNameLength</span><span class="o">=</span><span class="k">${#</span><span class="nv">liba</span><span class="k">}</span>

		<span class="c"># еОїеРОзЉАеРНзІ∞</span>
		<span class="nv">name</span><span class="o">=</span><span class="k">${</span><span class="nv">liba</span>:0:libNameLength-2<span class="k">}</span>

		<span class="c">#arm64 .a еРНзІ∞</span>
		<span class="nv">arm64Name</span><span class="o">=</span><span class="s2">"</span><span class="k">${</span><span class="nv">name</span><span class="k">}</span><span class="s2">_arm64.a"</span>

		<span class="c"># еИЖз¶їеЗЇ arm64 .a жЦЗдїґ</span>
		lipo <span class="s2">"</span><span class="nv">$recreateDir</span><span class="s2">/</span><span class="nv">$liba</span><span class="s2">"</span> <span class="nt">-thin</span> arm64 <span class="nt">-output</span> <span class="s2">"</span><span class="nv">$libExplit</span><span class="s2">/</span><span class="nv">$arm64Name</span><span class="s2">"</span>

		<span class="c"># armv7 .a еРНзІ∞</span>
		<span class="nv">armv7Name</span><span class="o">=</span><span class="s2">"</span><span class="k">${</span><span class="nv">name</span><span class="k">}</span><span class="s2">_armv7.a"</span>

		<span class="c"># еИЖз¶їеЗЇ armv7 .a жЦЗдїґ</span>
		lipo <span class="s2">"</span><span class="nv">$recreateDir</span><span class="s2">/</span><span class="nv">$liba</span><span class="s2">"</span> <span class="nt">-thin</span> armv7 <span class="nt">-output</span> <span class="s2">"</span><span class="nv">$libExplit</span><span class="s2">/</span><span class="nv">$armv7Name</span><span class="s2">"</span>

		<span class="c"># иОЈеПЦ .o жЦЗдїґ</span>
		<span class="nb">cd</span> <span class="nv">$odir64</span>
		ar <span class="nt">-x</span> <span class="s2">"</span><span class="nv">$libExplit</span><span class="s2">/</span><span class="nv">$arm64Name</span><span class="s2">"</span>
		<span class="nb">echo</span> <span class="s2">"</span><span class="nv">$arm64Name</span><span class="s2">"</span>

		<span class="nb">cd</span> <span class="nv">$odirv7</span>
		ar <span class="nt">-x</span> <span class="s2">"</span><span class="nv">$libExplit</span><span class="s2">/</span><span class="nv">$armv7Name</span><span class="s2">"</span>
		<span class="nb">echo</span> <span class="s2">"</span><span class="nv">$armv7Name</span><span class="s2">"</span>
	<span class="k">fi
done


</span><span class="nb">echo</span> <span class="s2">"4. е∞ЖеРМдЄАеє≥еП∞жЙАжЬЙ .o жЙУжИРжЦ∞зЪД .a жЦЗдїґ--&gt;"</span>
<span class="nb">cd</span> <span class="nv">$odir64</span>
libtool <span class="nt">-static</span> <span class="nt">-o</span> <span class="nv">$libArm64</span> <span class="k">*</span>.o
