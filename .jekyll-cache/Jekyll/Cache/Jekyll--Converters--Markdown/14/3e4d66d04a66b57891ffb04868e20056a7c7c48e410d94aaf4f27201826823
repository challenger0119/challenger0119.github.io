<span class="nb">cd</span> <span class="nv">$odirv7</span>
libtool <span class="nt">-static</span> <span class="nt">-o</span> <span class="nv">$libArmv7</span> <span class="k">*</span>.o
<span class="nb">echo</span> <span class="s2">"</span><span class="k">${</span><span class="nv">libName</span><span class="k">}</span><span class="s2">_armv7.a"</span>

<span class="nb">echo</span> <span class="s2">"5. еРИеєґдЄНеРМеє≥еП∞ .a жЦЗдїґ--&gt;"</span>
<span class="nb">cd</span> <span class="nv">$libResult</span>
lipo <span class="nt">-create</span> <span class="nv">$libArm64</span> <span class="nv">$libArmv7</span> <span class="nt">-output</span> <span class="s2">"</span><span class="k">${</span><span class="nv">libName</span><span class="k">}</span><span class="s2">.a"</span>
<span class="nb">echo</span> <span class="s2">"</span><span class="k">${</span><span class="nv">libName</span><span class="k">}</span><span class="s2">.a"</span>

<span class="nb">echo</span> <span class="s2">"6. жЛЈиіЭжЬАзїИзїУжЮЬ--&gt;"</span>
<span class="nb">echo</span> <span class="s2">"</span><span class="k">${</span><span class="nv">libName</span><span class="k">}</span><span class="s2">.a"</span>
<span class="nb">cp</span> <span class="nt">-f</span> <span class="s2">"</span><span class="nv">$libResult</span><span class="s2">/</span><span class="k">${</span><span class="nv">libName</span><span class="k">}</span><span class="s2">.a"</span> <span class="s2">"</span><span class="nv">$finalLibDir</span><span class="s2">/</span><span class="k">${</span><span class="nv">libName</span><span class="k">}</span><span class="s2">.a"</span>

<span class="k">for </span>lname <span class="k">in</span> <span class="k">${</span><span class="nv">libsToCopy</span><span class="p">[@]</span><span class="k">}</span>
<span class="k">do
	</span><span class="nb">echo</span> <span class="s2">"</span><span class="nv">$lname</span><span class="s2">"</span>
	<span class="nb">cp</span> <span class="nt">-rf</span> <span class="s2">"</span><span class="nv">$originLibDir</span><span class="s2">/</span><span class="nv">$lname</span><span class="s2">"</span> <span class="s2">"</span><span class="nv">$finalLibDir</span><span class="s2">/</span><span class="nv">$lname</span><span class="s2">"</span>
<span class="k">done


</span><span class="nb">echo</span> <span class="s2">"7. жШЊз§ЇжЬАзїИзїУжЮЬ--&gt;"</span>
open <span class="nv">$finalLibDir</span>

<span class="nb">echo</span> <span class="s2">"----еРИеєґзїУжЭЯ----"</span>
</code></pre></div></div>

